n, D = map(int, input().split())
# Если D = 0, то можно взять n единиц
if D == 0:
    print(n)
else:
    # Минимальная сумма для k чисел: 1 + (1+D) + (1+2D) + ... + (1+(k-1)D) =
    # = k*1 + D*(0+1+...+(k-1)) = k + D * k*(k-1)//2
    # Ищем максимальное k, при котором это <= n
    k = 1
    while True:
        min_sum = k + D * k * (k - 1) // 2
        if min_sum > n:
            print(k - 1)
            break
        k += 1
