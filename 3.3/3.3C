n = int(input())
a = list(map(int, input().split()))

a.sort()

# Максимальное произведение может быть:
# 1) произведение трёх самых больших положительных (или просто больших)
# 2) произведение двух самых маленьких (отрицательных) и самого большого
candidate1 = a[-1] * a[-2] * a[-3]
candidate2 = a[0] * a[1] * a[-1]

print(max(candidate1, candidate2))
